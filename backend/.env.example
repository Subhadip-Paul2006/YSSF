# Backend Environment Variables
DATABASE_URL=postgresql://user:password@localhost:5432/yssf
JWT_SECRET=your-super-secret-jwt-key-change-this
FRONTEND_URL=https://your-frontend.vercel.app
PORT=3001
NODE_ENV=production

# SMTP Configuration for OTP/Verification emails (Optional fallback, blocked on Render Free Tier)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL="YSSF Portal <your-email@gmail.com>"

# HTTP Email API Keys (Recommended for Render Free Tier hosting, works over port 443)
# Register at resend.com or brevo.com to get an API key.
# Set either of the keys below:
RESEND_API_KEY=
BREVO_API_KEY=


